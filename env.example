# ============================================================
# MEMOVIA DASHBOARD — Variables d'environnement
# ============================================================
# Copier ce fichier en .env.local et remplir les vraies valeurs
# NE JAMAIS committer .env.local sur Git
# ============================================================

# ------------------------------------------------------------
# SUPABASE (projet existant MEMOVIA)
# Dashboard Supabase > Settings > API
# ------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # Uniquement dans les Edge Functions, jamais côté client

# ------------------------------------------------------------
# STRIPE
# Dashboard Stripe > Developers > API keys
# ------------------------------------------------------------
STRIPE_SECRET_KEY=                # sk_live_... (Edge Function uniquement)
VITE_STRIPE_PUBLISHABLE_KEY=      # pk_live_... (côté client OK)
STRIPE_WEBHOOK_SECRET=            # whsec_... (pour valider les webhooks)

# ------------------------------------------------------------
# QONTO
# Qonto > Paramètres > Intégrations > API
# ------------------------------------------------------------
QONTO_API_KEY=
QONTO_ORGANIZATION_SLUG=          # Identifiant de votre organisation Qonto

# ------------------------------------------------------------
# GOOGLE CALENDAR (API)
# console.cloud.google.com > APIs > Google Calendar API
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ------------------------------------------------------------
# MICROSOFT GRAPH API (Outlook Emir)
# portal.azure.com > App registrations
# ------------------------------------------------------------
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ------------------------------------------------------------
# HOSTINGER EMAIL
# Email : contact@memovia.io (ou votre email Hostinger)
# ------------------------------------------------------------
HOSTINGER_EMAIL=
HOSTINGER_PASSWORD=
HOSTINGER_IMAP_HOST=imap.hostinger.com
HOSTINGER_IMAP_PORT=993
HOSTINGER_SMTP_HOST=smtp.hostinger.com
HOSTINGER_SMTP_PORT=465

# ------------------------------------------------------------
# GITHUB
# GitHub > Settings > Developer settings > Personal access tokens
# Scopes nécessaires : repo (read), actions (read)
# ------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO_OWNER=                # Votre username ou org GitHub
GITHUB_REPO_NAME=                 # Nom du repo app.memovia.io

# ------------------------------------------------------------
# DATAFORSEO
# app.dataforseo.com > API access
# ------------------------------------------------------------
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ------------------------------------------------------------
# ANTHROPIC API (pour le copilote IA et génération SEO)
# console.anthropic.com > API Keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# MODULE 16 — COÛTS API (Edge Functions uniquement)
# ------------------------------------------------------------
# OpenAI — clé Admin org requise pour /v1/organization/costs
# platform.openai.com/settings/organization/api-keys
OPENAI_API_KEY=                   # sk_... (Admin org key recommandé)

# Gemini — pas d'API de facturation via clé API
# Consulter : console.cloud.google.com/billing
# (pas de variable nécessaire pour ce module)

# Gladia — clé API standard
# app.gladia.io/settings/api-keys
GLADIA_API_KEY=                   # clé x-gladia-key

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
VITE_APP_URL=http://localhost:5173  # En prod : https://dashboard.memovia.io
NODE_ENV=development
